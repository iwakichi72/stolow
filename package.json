{
  "name": "stolow",
  "version": "0.1.0",
  "private": true,
  "description": "Stolow - an AI-assisted desktop editor for novel writing.",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json && vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.6.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
